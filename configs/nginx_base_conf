# Shared nginx config for both HTTP and HTTPS

gzip_min_length     1000;
gzip_buffers        4 8k;
gzip_http_version   1.0;
gzip_disable        "msie6";
gzip_vary           on;
gzip on;
gzip_proxied any;
gzip_types
    text/css
    text/javascript
    text/xml
    text/plain
    application/javascript
    application/x-javascript
    application/json;

# Resolve app/north via Docker's embedded DNS at request time (rather than
# once at nginx startup) so recreating those containers - which gives them a
# new internal IP each time - doesn't require restarting this proxy too.
# proxy_pass needs a variable (not a bare hostname) for this to take effect.
resolver 127.0.0.11 valid=10s;

location / {
    set $backend_app http://app:8000;
    proxy_pass $backend_app;
}

location ~ /nomad-oasis\/?(gui)?$ {
    rewrite ^ /nomad-oasis/gui/ permanent;
}

location /nomad-oasis/gui/ {
    proxy_intercept_errors on;
    error_page 404 = @redirect_to_index;
    set $backend_app http://app:8000;
    proxy_pass $backend_app;
}

location @redirect_to_index {
    rewrite ^ /nomad-oasis/gui/index.html break;
    set $backend_app http://app:8000;
    proxy_pass $backend_app;
}

location /nomad-oasis/docs/ {
    # This is added to force a redirect (302) when 404 otherwise
    # the assets are not loaded correctly (a broken page rendered)
    proxy_intercept_errors on;
    error_page 404 = @docs404redirect;
    set $backend_app http://app:8000;
    proxy_pass $backend_app;
}

location @docs404redirect {
    return 302 /nomad-oasis/docs/404.html;
}

location ~ \/gui\/(service-worker\.js|meta\.json)$ {
    add_header Last-Modified $date_gmt;
    add_header Cache-Control 'no-store, no-cache, must-revalidate, proxy-revalidate, max-age=0';
    if_modified_since off;
    expires off;
    etag off;
    set $backend_app http://app:8000;
    proxy_pass $backend_app;
}

location ~ /api/v1/uploads(/?$|.*/raw|.*/bundle?$)  {
    client_max_body_size 35g;
    proxy_request_buffering off;
    set $backend_app http://app:8000;
    proxy_pass $backend_app;
}

location ~ /api/v1/.*/download {
    proxy_buffering off;
    set $backend_app http://app:8000;
    proxy_pass $backend_app;
}

location /nomad-oasis/north/ {
    client_max_body_size 500m;
    set $backend_north http://north:9000;
    proxy_pass $backend_north;

    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header Host $host;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;

    # websocket headers
    proxy_http_version 1.1;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection $connection_upgrade;
    proxy_set_header X-Scheme $scheme;

    proxy_buffering off;
}
